{
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": "text/html"
        }
      ],
      "destination": "/maintenance",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/maintenance",
      "destination": "/index.html"
    }
  ]
}
