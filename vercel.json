{
  "redirects": [
    {
      "source": "/((?!maintenance|assets|public|.*\\.(svg|png|jpg|jpeg|gif|css|js|ico)).*)",
      "destination": "/maintenance",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/maintenance",
      "destination": "/index.html"
    },
    {
      "source": "/((?!maintenance).*)",
      "destination": "/index.html"
    }
  ]
}
