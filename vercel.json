{
  "redirects": [
    {
      "source": "/((?!maintenance|assets|public).*)",
      "destination": "/maintenance",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/maintenance",
      "destination": "/index.html"
    },
    {
      "source": "/((?!maintenance).*)",
      "destination": "/index.html"
    }
  ]
}
